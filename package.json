{
  "name": "GodDidMart",
  "version": "0.4.5",
  "private": true,
  "main": "build/electron/main.js",
  "homepage": "./",
  "build": {
    "appId": "com.goddidmart.app",
    "productName": "GodDid Mart",
    "directories": {
      "output": "output"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/logo512.png",
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logo512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/logo512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "scripts": {
    "start": "serve -s build",
    "dev": "react-scripts start",
    "build": "CI=false react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    
    "clean": "rm -rf build dist output",
    "copy:electron": "mkdir -p build/electron && cp electron/*.js build/electron/ && cp electron/*.html build/electron/ 2>/dev/null || :",
    "postbuild": "npm run copy:electron",
    
    "electron:start": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:dev\"",
    "electron:dev": "electron build/electron.js",
    "electron:prod": "NODE_ENV=production electron build/electron.js",
    
    "dist": "npm run clean && npm run build && electron-builder --mac --win --linux",
    "dist:mac": "npm run clean && npm run build && electron-builder --mac",
    "dist:win": "npm run clean && npm run build && electron-builder --win",
    "dist:linux": "npm run clean && npm run build && electron-builder --linux"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "react/prop-types": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react-dom": "^19.2.1",
    "axios": "^1.12.2",
    "crypto-js": "^4.2.0",
    "electron-updater": "^6.7.3",
    "html2canvas": "^1.4.1",
    "import": "^0.0.6",
    "jspdf": "^3.0.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "react-scripts": "5.0.1",
    "recharts": "^3.7.0",
    "remixicon": "^4.6.0",
    "sonner": "^2.0.7",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.1",
    "@types/react": "^19.2.2",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "env-cmd": "^11.0.0",
    "postcss": "^8.5.6",
    "serve": "^14.2.5",
    "tailwindcss": "^3.4.17",
    "wait-on": "^9.0.3"
  }
}